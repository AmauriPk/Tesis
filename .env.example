RTSP_URL=rtsp://IP_DE_LA_CAMARA:554/Streaming/Channels/101
RTSP_USERNAME=usuario_rtsp
RTSP_PASSWORD=contraseña_rtsp

ONVIF_HOST=IP_DE_LA_CAMARA
ONVIF_PORT=80
ONVIF_USERNAME=usuario_onvif
ONVIF_PASSWORD=contraseña_onvif

# PTZ - Inspección automática (patrullaje horizontal)
PTZ_INSPECTION_MODE=sweep
PTZ_INSPECTION_CONTINUOUS_360=1
PTZ_INSPECTION_SPEED=0.85
PTZ_INSPECTION_DURATION=16.0
PTZ_INSPECTION_PAUSE=0.8

# PTZ - Tracking automático
PTZ_TRACKING_SPEED=0.35
PTZ_TRACKING_DURATION=0.35
PTZ_TRACKING_MIN_SPEED=0.12
PTZ_TRACKING_MAX_SPEED=0.45
PTZ_TRACKING_DEADZONE_FRAC=0.10
PTZ_TRACKING_COMMAND_INTERVAL=0.35
PTZ_TRACKING_TARGET_TTL=1.5
PTZ_TRACKING_PAN_SPEED=0.35
PTZ_TRACKING_TILT_SPEED=0.60
PTZ_TRACKING_PAN_DURATION=0.30
PTZ_TRACKING_TILT_DURATION=0.55
PTZ_TRACKING_EDGE_MARGIN_FRAC=0.08
PTZ_TRACKING_EDGE_TILT_BOOST=1.25
